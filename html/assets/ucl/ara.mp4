</span><span class="x1lliihq">    &lt;meta charset="UTF-8"&gt;
</span><span class="x1lliihq">    &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
</span><span class="x1lliihq">    &lt;title&gt;IPL 2026&lt;/title&gt;
</span><span class="x1lliihq">    &lt;link rel="icon" type="image/icon" href="../assets/favicon_io/favicon.ico"&gt;
</span><span class="x1lliihq">    &lt;meta name="description"
